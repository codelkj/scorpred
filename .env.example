# Copy this file to .env and fill in your real keys.
# Never commit .env to version control.

# ── Football API (RapidAPI) ───────────────────────────────────────────────────
API_FOOTBALL_KEY=your_rapidapi_key_here
API_FOOTBALL_MODE=rapidapi
API_FOOTBALL_BASE_URL=https://api-football-v1.p.rapidapi.com/v3
API_FOOTBALL_HOST=api-football-v1.p.rapidapi.com

# ── NBA API (RapidAPI) ────────────────────────────────────────────────────────
NBA_API_KEY=your_rapidapi_key_here
NBA_API_HOST=nba-api-free-data.p.rapidapi.com
NBA_API_BASE_URL=https://nba-api-free-data.p.rapidapi.com

# ── Claude AI chatbot (Anthropic) ─────────────────────────────────────────────
# Get your key at https://console.anthropic.com
# Without this key the chatbot uses a built-in fallback responder.
ANTHROPIC_API_KEY=REDACTED_ANTHROPIC_API_KEY


# ── The Odds API ─────────────────────────────────────────────────────────────
# Get your key at https://the-odds-api.com
# Without this key, edge badges are hidden in the matchup view.
ODDS_API_KEY=dc2c961bc1b2f483d5c9482d65686cec

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=0
FLASK_USE_RELOADER=0
PORT=5000

# ── Local runtime storage (optional) ─────────────────────────────────────────
# By default, generated cache/tracking/report files are stored under <repo>/cache.
# Set this to a persistent disk path (e.g. /persistent) for production (Render, etc).
# All tracked data, reports, and user accounts will be stored under this root.
SCORPRED_DATA_ROOT=
