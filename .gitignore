# Environment & secrets
.env
.env.local
.env.*.local
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
*.whl
pip-wheel-metadata/
.pytest_cache/

# Virtual environments
venv/
env/
.venv/
venv313/
ENV/

# Transient HTTP response caches — NOT committed
cache/football/
cache/nba/
cache/nba_public/
cache/props/

# Live prediction ledger — written by the running app, NOT committed to git.
# It lives on the deployed server and is read by daily_refresh.py there.
# GitHub Actions pipeline steps that need it (learn_from_mistakes,
# optimize_policy) are gracefully skipped when this file is absent.
cache/prediction_tracking.json
cache/prediction_history.json

# ML artifacts (model comparison, policy) ARE committed so GitHub Actions
# can read and update them between deploys.
# cache/ml/ is intentionally NOT ignored here.

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Binary model files — large, regenerated by weekly_retrain.py.
# Stored as GitHub Actions workflow artifacts, not in git.
data/models/*.pkl

# Pipeline run logs (JSONL) ARE committed so historical runs are auditable.
# Plain *.log files (external tooling) are NOT.
*.log

# Local AI/tooling state
.claude/
.tmp/
tmp/
tmp_work/

# Runtime databases (generated by the app, not tracked)
persistent/
*.db
